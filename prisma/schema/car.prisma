model Car {
  id        String @id @default(uuid()) @db.Uuid
  profileId String @db.Uuid
  garageId  String @db.Uuid

  profile Profile @relation(fields: [profileId], references: [id])
  garage  Garage  @relation(fields: [garageId], references: [id])

  image             String?
  make              String?
  model             String?
  bodyType          BodyType          @default(CLASSIC)
  transmission      Transmission      @default(MANUAL)
  driveTrain        DriveTrain        @default(RWD)
  country           String?
  color             String?
  displayName       String?
  description       String?
  category          DriveCategory     @default(DAILY_DRIVE)
  listOnMarketplace Boolean           @default(false)
  price             Int?
  advancedCarDatas  AdvancedCarData[]
  legalNotices      LegalNotice[]

  splitScreenMatchRequests SplitScreenMatchRequest[]

  splitScreenBattlesLeftUser SplitScreenBattle[] @relation("SplitScreenLeftCar")

  splitScreenBattleParticipants SplitScreenBattleParticipant[]

  splitScreenBattlesRightUser SplitScreenBattle[] @relation("SplitScreenRightCar")
}
