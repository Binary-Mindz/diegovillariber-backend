model WheelsTires {
  id                String          @id @default(uuid()) @db.Uuid
  advancedCarDataId String          @unique @db.Uuid
  advancedCarData   AdvancedCarData @relation(fields: [advancedCarDataId], references: [id])

  tires          String?
  wheels         String?
  frontCamber    Float?
  rearCamber     Float?
  frontToe       Float?
  rearToe        Float?
  frontCaster    Float?
  alignmentNotes String?
}
