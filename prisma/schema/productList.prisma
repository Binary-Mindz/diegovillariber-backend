model ProductList {
  id String @id @default(uuid()) @db.Uuid

  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  carId String? @unique @db.Uuid
  car   Car?    @relation(fields: [carId], references: [id], onDelete: Cascade)

  // form fields
  title           String
  productImage    String?
  location        String?
  locationAddress String?
  latitude        Decimal?        @db.Decimal(9, 6)
  longitude       Decimal?        @db.Decimal(9, 6)
  placeId         String?
  description     String?
  category        ProductCategory @default(CAR)

  tags String[] @default([]) // comma separated in UI -> store as array

  carBrand String?
  carModel String?

  price    Int
  quantity Int

  showWhatsappNo   Boolean  @default(false) // "Show my WhatsApp No" toggle
  highlightProduct Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
