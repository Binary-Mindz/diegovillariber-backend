model Garage {
  id        String  @id @default(uuid()) @db.Uuid
  profileId String  @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  garageName  String?
  description String?
  location    String?

  cars  Car[]
  bikes Bike[]

  @@index([profileId])
}
