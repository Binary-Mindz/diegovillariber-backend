model SpottingMatch {
  id                String @id @default(uuid()) @db.Uuid
  spottingRequestId String @db.Uuid
  postId            String @db.Uuid
  spottedUserId     String @db.Uuid
  distanceKm        Float?

  createdAt DateTime @default(now())

  spottingRequest SpottingRequest @relation(fields: [spottingRequestId], references: [id], onDelete: Cascade)
  post            Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  spottedUser     User            @relation(fields: [spottedUserId], references: [id], onDelete: Cascade)

  @@unique([spottingRequestId, postId])
  @@index([spottingRequestId])
  @@index([postId])
}
