model RacingVote {
  id String @id @default(uuid()) @db.Uuid

  voterId String @db.Uuid
  voter   User   @relation("RacingVoteVoter", fields: [voterId], references: [id])

  targetUserId String? @db.Uuid
  targetUser   User?   @relation("RacingVoteReceiver", fields: [targetUserId], references: [id])

  postId String? @db.Uuid
  post   Post?   @relation(fields: [postId], references: [id])

  point     Int      @default(5)
  createdAt DateTime @default(now())

  @@index([voterId, createdAt])
  @@index([targetUserId])
  @@index([postId])
}