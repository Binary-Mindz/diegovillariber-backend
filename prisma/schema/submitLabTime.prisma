model SubmitLabTime {
  id String @id @default(uuid()) @db.Uuid

  profileId String  @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  simPlatform Platform @default(iRacing)
  circuit     Circuit  @default(Spa_Francorchamps)

  carName  String?
  carClass CarClass @default(DRIFT)

  lapTimeMs   Int
  sessionDate DateTime @db.Timestamptz(6)

  videoLink       String?         @db.VarChar(500)
  telemetrySource TelemetrySource @default(iRacing_MoTec)
  telemetryData   String?         @db.Text

  tractionControl Boolean @default(false)
  abs             Boolean @default(false)
  stability       Boolean @default(false)
  autoClutch      Boolean @default(false)
  racingLine      Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([profileId])
  @@index([circuit])
  @@index([carClass])
  @@index([simPlatform])
  @@index([lapTimeMs])
  @@index([circuit, carClass, lapTimeMs])
  @@index([profileId, circuit])
  @@map("SubmitLabTime")
}
