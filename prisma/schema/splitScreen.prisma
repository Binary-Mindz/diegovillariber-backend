enum SplitScreenArenaStatus {
  ACTIVE
  INACTIVE
}

enum SplitScreenMatchStatus {
  SEARCHING
  MATCHED
  CANCELLED
  EXPIRED
}

enum SplitScreenBattleStatus {
  PENDING
  LIVE
  COMPLETED
  CANCELLED
}

enum SplitScreenBattleCategory {
  STYLES
  RACING
  CLASSIC
  STANCE
  DRIFT
  OFF_ROAD
}

enum SplitScreenMatchmakingMode {
  ANYONE
  ONLINE_ONLY
}

enum SplitScreenPreferenceMode {
  ANY_CAR_BRAND
  SAME_BRAND_ONLY
  SAME_MODEL_ONLY
  SPECIFIC_BRAND
  SIMILAR_PRESTIGE
}

enum SplitScreenLeagueCode {
  WORLD
  EUROPE
  USA
  UK
  FRANCE
  GERMANY
  SPAIN
}

enum SplitScreenDivision {
  D1
  D2
  D3
}

enum SplitScreenVoteType {
  LEFT
  RIGHT
}

enum SplitScreenParticipantResult {
  WIN
  LOSS
  DRAW
}

model SplitScreenMatchRequest {
  id String @id @default(uuid()) @db.Uuid

  userId    String @db.Uuid
  profileId String @db.Uuid
  carId     String @db.Uuid

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  car     Car     @relation(fields: [carId], references: [id], onDelete: Cascade)

  league   SplitScreenLeagueCode
  division SplitScreenDivision

  matchmakingMode SplitScreenMatchmakingMode @default(ANYONE)
  preferenceMode  SplitScreenPreferenceMode  @default(ANY_CAR_BRAND)
  preferredBrand  String?
  battleCategory  SplitScreenBattleCategory

  prestigePoint Int? // optional if later needed for similar prestige matching

  status SplitScreenMatchStatus @default(SEARCHING)

  matchedBattleId String?            @db.Uuid
  matchedBattle   SplitScreenBattle? @relation("BattleFromRequest", fields: [matchedBattleId], references: [id])

  expiresAt   DateTime?
  cancelledAt DateTime?
  matchedAt   DateTime?

  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  splitScreenBattlesLeftUser  SplitScreenBattle[] @relation("LeftRequestBattle")
  splitScreenBattlesRightUser SplitScreenBattle[] @relation("RightRequestBattle")
  programType  ProgramType @default(SPLIT_SCREEN)
  @@index([status, league, division, battleCategory])
  @@index([userId, status])
  @@index([profileId])
  @@index([carId])
}

model SplitScreenBattle {
  id String @id @default(uuid()) @db.Uuid

  league   SplitScreenLeagueCode
  division SplitScreenDivision
  category SplitScreenBattleCategory

  matchmakingMode SplitScreenMatchmakingMode @default(ANYONE)
  preferenceMode  SplitScreenPreferenceMode  @default(ANY_CAR_BRAND)
  preferredBrand  String?

  leftUserId    String @db.Uuid
  leftProfileId String @db.Uuid
  leftCarId     String @db.Uuid

  rightUserId    String @db.Uuid
  rightProfileId String @db.Uuid
  rightCarId     String @db.Uuid

  leftUser    User    @relation("SplitScreenLeftUser", fields: [leftUserId], references: [id], onDelete: Cascade)
  leftProfile Profile @relation("SplitScreenLeftProfile", fields: [leftProfileId], references: [id], onDelete: Cascade)
  leftCar     Car     @relation("SplitScreenLeftCar", fields: [leftCarId], references: [id], onDelete: Cascade)

  rightUser    User    @relation("SplitScreenRightUser", fields: [rightUserId], references: [id], onDelete: Cascade)
  rightProfile Profile @relation("SplitScreenRightProfile", fields: [rightProfileId], references: [id], onDelete: Cascade)
  rightCar     Car     @relation("SplitScreenRightCar", fields: [rightCarId], references: [id], onDelete: Cascade)

  leftRequestId  String? @unique @db.Uuid
  rightRequestId String? @unique @db.Uuid

  leftRequest  SplitScreenMatchRequest? @relation("LeftRequestBattle", fields: [leftRequestId], references: [id])
  rightRequest SplitScreenMatchRequest? @relation("RightRequestBattle", fields: [rightRequestId], references: [id])

  status SplitScreenBattleStatus @default(LIVE)

  totalVotes    Int @default(0)
  leftVotes     Int @default(0)
  rightVotes    Int @default(0)
  entryPrestige Int @default(300)
  prizePool     Int @default(450)

  winnerSide SplitScreenVoteType?

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  cancelledAt DateTime?

  votes        SplitScreenBattleVote[]
  participants SplitScreenBattleParticipant[]
  requests     SplitScreenMatchRequest[]      @relation("BattleFromRequest")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, league, division])
  @@index([leftUserId])
  @@index([rightUserId])
}

model SplitScreenBattleParticipant {
  id String @id @default(uuid()) @db.Uuid

  battleId  String @db.Uuid
  userId    String @db.Uuid
  profileId String @db.Uuid
  carId     String @db.Uuid

  side SplitScreenVoteType

  votes  Int                           @default(0)
  result SplitScreenParticipantResult?

  battle  SplitScreenBattle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  car     Car               @relation(fields: [carId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([battleId, side])
  @@index([userId])
  @@index([profileId])
  @@index([carId])
}

model SplitScreenBattleVote {
  id String @id @default(uuid()) @db.Uuid

  battleId String              @db.Uuid
  voterId  String              @db.Uuid
  vote     SplitScreenVoteType

  battle SplitScreenBattle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  voter  User              @relation(fields: [voterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([battleId, voterId])
  @@index([battleId, vote])
}
