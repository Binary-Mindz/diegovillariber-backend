model Battle {
  id     String @id @default(uuid()) @db.Uuid
  hostId String @db.Uuid
  host   User   @relation("HostBattles", fields: [hostId], references: [id])

  title       String
  description String?
  coverImage  String?

  battleCategory BattleCategory @default(RAW_SHIFT)
  preference     Preference     @default(CAR)

  status          BattleStatus @default(DRAFT)
  maxParticipants Int          @default(10)

  startTime DateTime?
  endTime   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userPoints   UserPoint[]
 

  @@index([status])
}
