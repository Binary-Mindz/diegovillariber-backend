model UsageNotes {
  id                String          @id @default(uuid()) @db.Uuid
  advancedCarDataId String          @unique @db.Uuid
  advancedCarData   AdvancedCarData @relation(fields: [advancedCarDataId], references: [id])

  category       UsageCategory @default(Street)
  driverLevel    DriverLevel   @default(Amateur)
  usageMode      UsageMode     @default(Daily)
  alignmentNotes String?
}
