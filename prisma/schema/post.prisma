model Post {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  profileId String?  @db.Uuid
  profile   Profile? @relation(fields: [profileId], references: [id])
  profileType        Type?
  postType           PostType @default(Spotter_Post)
  caption            String?
  mediaUrl           String?
  postLocation       String?
  locationName       String?
  locationAddress    String?
  latitude           Decimal? @db.Decimal(9, 6)
  longitude          Decimal? @db.Decimal(9, 6)
  placeId            String?
  locationVisibility String?

  vehicleCategory    VehicleCategory @default(CLASSIC)
  mediaType      MediaType @default(IMAGE)
  like           Int     @default(0)
  comment        Int     @default(0)
  share          Int     @default(0)
  contentBooster Boolean @default(false)
  point          Int     @default(5)
  photoEditingDeclaration  PhotoEditingDeclaration? 
  videoEditingDeclaration  VideoEditingDeclaration?
  
  taggedUsers User[] @relation("PostTaggedUsers")

  visiualStyle    VisiualStyle[]    @default([])
  contextActivity ContextActivity[] @default([])
  subject         Subject[]         @default([])
  hashtags    Hashtag[]    @relation("PostHashtags")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  reposts     Repost[]
  racingVotes RacingVote[]
  savePosts   SavePost[]
  hidePosts   HidePost[]
  wishLists   WishList[]
  userPoints  UserPoint[]

  likes    Like[]
  comments Comment[]
}

enum PhotoEditingDeclaration {
  NO_EDITING
  EDITED_WITH_ADOBE_LIGHTROOM
  EDITED_WITH_ADOBE_PHOTOSHOP
  EDITED_WITH_SNAPSEED
  EDITED_WITH_VSCO
  EDITED_WITH_OTHER_SOFTWARE
}

enum VideoEditingDeclaration {
  ADOBE_PREMIER_PRO
  DAVINCI_RESOLVE
  AVID_MEDIA_COMPOSER
  FINAL_CUT_PRO
}

