model HardwareSetup {
  id          String           @id @default(uuid()) @db.Uuid
  simRacingId String           @unique @db.Uuid
  simRacing   SimRacingProfile @relation(fields: [simRacingId], references: [id], onDelete: Cascade)

  steeringWheel SteeringWheel @default(FANATEC)
  wheelModel    WheelModel @default(LOGITECH)
  wheelbase     WheelBase @default(DESK_MOUNT)
  pedals        String?
  pedelModel    String?
  shifter       String?
  handbrake     String?
  rig           String?
  rigBrand      String?
  seatBrand     String?
  buttonBox     String?

  bassShakers  Boolean @default(true)
  windSim      Boolean @default(false)
  racingGloves Boolean @default(false)
  racingShoes  Boolean @default(true)

  @@map("HardwareSetup")
}