model Profile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeType       Type?
  profileName      String?
  bio              String?
  imageUrl         String?
  instagramHandler String?
  accountType      AccountType @default(PUBLIC)
  preference       Preference?

  isActive       IsActive @default(ACTIVE)
  suspend        Boolean  @default(false)
  locationStatus Boolean  @default(false)

  shareSlug      String?   @unique
  shareQrPath    String?
  shareCount     Int       @default(0)

  spotter   SpotterProfile?
  owner     OwnerProfile?
  creator   ContentCreatorProfile?
  business  BusinessProfile?
  proDriver ProDriverProfile?
  simRacing SimRacingProfile?

  garages                Garage[]
  cars                   Car[]
  virtualGarages         VirtualGarage[]
  virtualSimRacingEvents VirtualSimRacingEvent[]
  legalNotices           LegalNotice[]
  posts                  Post[]
  labTimes               LabTime[]
  submitLabTimes         SubmitLabTime[]
  bikes                  Bike[]

  splitScreenMatchRequests SplitScreenMatchRequest[]

  splitScreenBattlesLeftUser SplitScreenBattle[] @relation("SplitScreenLeftProfile")

  splitScreenBattleParticipants SplitScreenBattleParticipant[]

  splitScreenBattlesRightUser SplitScreenBattle[] @relation("SplitScreenRightProfile")

  spottingRequests SpottingRequest[]

  profileBadges ProfileBadge[]
}
