model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique
  phone             String?
  password          String
  role              Role      @default(USER)
  activeRole        Role?
  otp               String?
  expiresIn         String?
  isEmailVerified   Boolean   @default(false)
  accountStatus     AccountStatus  @default(ACTIVE)
  emailOtp          String?
  emailOtpExpiresAt DateTime?
  resetOtp          String?
  resetOtpExpiresAt DateTime?
  refreshTokenHash  String?
  totalPoints       Int       @default(0)
  balance           Int       @default(0)
  likeCount         Int       @default(0)
  commentCount      Int       @default(0)
  shareCount        Int       @default(0)
  activeProfileId   String?   @db.Uuid

  profile  Profile[]
  posts    Post[]
  events   Event[]
  payments Payment[]

  following             Follow[]               @relation("UserFollowing")
  followers             Follow[]               @relation("UserFollowers")
  
  productLists          ProductList[]
  reports               Report[]
  shares                Share[]
  likes                 Like[]
  comments              Comment[]
  liveRewards           LiveReward[]           @relation("RewardHost")
  liveRewardsGiven      LiveReward[]           @relation("RewardParticipant")
  lives                 Live[]                 @relation("HostedLives")
  liveParticipants      LiveParticipant[]
  reposts               Repost[]
  racingVotes           RacingVote[]
  savePosts             SavePost[]
  hidePosts             HidePost[]
  wishLists             WishList[]
  battleParticipants    BattleParticipant[]
  userPoints            UserPoint[]
  challenges            Challenge[]
  challengeParticipants ChallengeParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  officialPartners   OfficialPartner?
  ambassadorPrograms AmbassadorProgram?

  conversationParticipants ConversationParticipant[]

  messages Message[] @relation("SentMessages")

  messageReceipts MessageReceipt[]

  taggedInPosts Post[] @relation("PostTaggedUsers")

  
  headToHeadBattlesCreated HeadToHeadBattle[] @relation("H2HCreator")

  headToHeadBattlesWon HeadToHeadBattle[] @relation("H2HWinner")

  battleInvitationsInviter BattleInvitation[] @relation("H2HInviter")

  battleInvitationsInvitte BattleInvitation[] @relation("H2HInvitee")

  battleSubmissions BattleSubmission[]

  battleVotes BattleVote[]

  battleComments BattleComment[]

  rawShiftBattlesCreated RawShiftBattle[] @relation("RawShiftCreator")

  rawShiftBattlesWon RawShiftBattle[] @relation("RawShiftWinner")

  rawShiftParticipants RawShiftParticipant[]

  rawShiftEntries RawShiftEntry[]

  rawShiftVotes RawShiftVote[]

  rawShiftComments RawShiftComment[]

  prizes Prize[]

  challengeReactions ChallengeReaction[]

  challengeVotes ChallengeVote[]

  challengeComments ChallengeComment[]

  notificationPreferences NotificationPreference[]

  notifications Notification[]

  notificationsActor Notification[] @relation("NotificationActor")

  deviceTokens DeviceToken[]

  splitScreenBattlesCreator SplitScreenBattle[] @relation("SplitScreenBattleCreator")

  splitScreenBattlesWinner SplitScreenBattle[] @relation("SplitScreenBattleWinner")

  splitScreenResults SplitScreenResult[] @relation("SplitScreenBattleResultUser")

  splitScreenRewards SplitScreenReward[] @relation("SplitScreenBattleRewardUser")

  splitScreenVotes SplitScreenVote[] @relation("SplitScreenBattleVoteVoter")

  splitScreenParticipants SplitScreenParticipant[] @relation("SplitScreenBattleParticipant")
}
