model EnginePower {
  id                String          @id @default(uuid()) @db.Uuid
  advancedCarDataId String          @unique @db.Uuid
  advancedCarData   AdvancedCarData @relation(fields: [advancedCarDataId], references: [id], onDelete: Cascade)

  horsepowerHp        Int?
  torqueNm            Int?
  weightKg            Int?
  engineDescription   String?
  fuelType            FuelType @default(Gasoline)
  turboOrSupercharger String?
  intercooler         String?
  exhaustSystem       String?
  intakeSystem        String?
  fuelSystemMods      String?
  coolingUpgrades     String?

  dynoWeightKg Int?
  rpmLimiter   Int?
}
