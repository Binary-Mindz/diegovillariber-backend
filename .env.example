# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Dev Docker uses port 5433 (mapped to 5432 internally). Local Postgres typically uses 5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/diego_db?schema=public"

# Database Credentials (used by Docker Compose build)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=diego_db

# Redis Configuration (used by Docker Compose build)
REDIS_PASSWORD=redis_secure_password

# Authentication (JWT)
JWT_ACCESS_SECRET=your_jwt_access_secret_key_change_me
JWT_ACCESS_EXPIRES=1d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me
JWT_REFRESH_EXPIRES=7d

# Social Authentication
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Mail Configuration (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=diego.villar.ibero@gmail.com
MAIL_PASS=cpvb dqun amsc dqxw
MAIL_FROM=diego.villar.ibero@gmail.com

# Admin Account Seeding Settings
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123

# Application & Profile Sharing Configuration
APP_BASE_URL=http://localhost:5000
PROFILE_SHARE_PATH=/profile

# Cloudflare R2 Storage (File Uploads)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_BUCKET_NAME=your_r2_bucket_name
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxx.r2.dev
CLOUDFLARE_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_SECRET_ACCESS_KEY=your_r2_secret_access_key

